{
  "@context": {
    "ion": "https://schema.ion.id/trade/performance/v1#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#"
  },
  "@graph": [
    {
      "@id": "ion:TradePerformanceAttributes",
      "@type": "rdfs:Class",
      "rdfs:label": "TradePerformanceAttributes",
      "rdfs:comment": "TradePerformanceAttributes"
    },
    {
      "@id": "ion:performanceMode",
      "@type": "rdf:Property",
      "rdfs:label": "performanceMode",
      "rdfs:comment": "How the fulfilment is executed. DELIVERY: logistics delivers to buyer address. SELF_PICKUP: buyer collects from seller location. DINE_IN: for restaurant orders consumed on premises. CURBSIDE: buyer drives to pickup point, seller brings to car.\n"
    },
    {
      "@id": "ion:supportedPerformanceModes",
      "@type": "rdf:Property",
      "rdfs:label": "supportedPerformanceModes",
      "rdfs:comment": "All performance modes supported by this provider for this offer. Declared in on_select. Buyer selects mode at init.\n"
    },
    {
      "@id": "ion:sla",
      "@type": "rdf:Property",
      "rdfs:label": "sla",
      "rdfs:comment": "Service Level Agreement for fulfilment timing."
    },
    {
      "@id": "ion:handling",
      "@type": "rdf:Property",
      "rdfs:label": "handling",
      "rdfs:comment": "Special handling requirements for this fulfilment. Determines logistics eligibility and surcharges.\n"
    },
    {
      "@id": "ion:readyToShip",
      "@type": "rdf:Property",
      "rdfs:label": "readyToShip",
      "rdfs:comment": "Seller signals that the package is physically ready for logistics pickup. Sent by BPP via /update. Triggers LSP to dispatch agent.\n"
    },
    {
      "@id": "ion:awbNumber",
      "@type": "rdf:Property",
      "rdfs:label": "awbNumber",
      "rdfs:comment": "Air Waybill number assigned by the logistics provider after pickup. Enables tracking on LSP platform.\n"
    },
    {
      "@id": "ion:trackingUrl",
      "@type": "rdf:Property",
      "rdfs:label": "trackingUrl",
      "rdfs:comment": "URL for real-time shipment tracking. Provided by logistics provider after pickup. BAP renders as tracking link or embedded tracker.\n"
    },
    {
      "@id": "ion:estimatedDeliveryTime",
      "@type": "rdf:Property",
      "rdfs:label": "estimatedDeliveryTime",
      "rdfs:comment": "Updated estimated delivery datetime in ISO 8601 with timezone. BPP updates dynamically as fulfilment progresses.\n"
    },
    {
      "@id": "ion:agentName",
      "@type": "rdf:Property",
      "rdfs:label": "agentName",
      "rdfs:comment": "Name of delivery agent or driver assigned to this fulfilment."
    },
    {
      "@id": "ion:agentPhone",
      "@type": "rdf:Property",
      "rdfs:label": "agentPhone",
      "rdfs:comment": "Indonesian mobile number, 10-13 digits."
    },
    {
      "@id": "ion:agentPhoto",
      "@type": "rdf:Property",
      "rdfs:label": "agentPhoto",
      "rdfs:comment": "URL to photo of delivery agent. Displayed by BAP for consumer security verification. URL must remain valid for 24 hours.\n"
    },
    {
      "@id": "ion:deliveryOtp",
      "@type": "rdf:Property",
      "rdfs:label": "deliveryOtp",
      "rdfs:comment": "One-time password required for agent to confirm delivery. Consumer shows OTP to agent at doorstep.\n"
    },
    {
      "@id": "ion:deliveryProofUrl",
      "@type": "rdf:Property",
      "rdfs:label": "deliveryProofUrl",
      "rdfs:comment": "URL to photo proof of delivery — package at door or consumer signature. Added at DELIVERED state.\n"
    },
    {
      "@id": "ion:selfPickupCode",
      "@type": "rdf:Property",
      "rdfs:label": "selfPickupCode",
      "rdfs:comment": "Unique code generated by BPP for self-pickup orders. Consumer presents this code at counter to collect order.\n"
    },
    {
      "@id": "ion:returnAgentName",
      "@type": "rdf:Property",
      "rdfs:label": "returnAgentName",
      "rdfs:comment": "Name of pickup agent for return collection."
    },
    {
      "@id": "ion:returnTrackingUrl",
      "@type": "rdf:Property",
      "rdfs:label": "returnTrackingUrl",
      "rdfs:comment": "Tracking URL for return shipment."
    },
    {
      "@id": "ion:installationScheduling",
      "@type": "rdf:Property",
      "rdfs:label": "installationScheduling",
      "rdfs:comment": "Installation appointment scheduling. Declared capability is in resource.installation. This carries the transaction-time appointment.\n"
    },
    {
      "@id": "ion:realTimeGps",
      "@type": "rdf:Property",
      "rdfs:label": "realTimeGps",
      "rdfs:comment": "Current GPS position of delivery agent. Updated via /track API. Not persisted — real-time only.\n"
    },
    {
      "@id": "ion:lspSubscriberId",
      "@type": "rdf:Property",
      "rdfs:label": "lspSubscriberId",
      "rdfs:comment": "Subscriber ID of the on-network logistics provider handling this fulfilment. Enables ION to trace the cascaded logistics contract.\n"
    },
    {
      "@id": "ion:shippingInsurance",
      "@type": "rdf:Property",
      "rdfs:label": "shippingInsurance",
      "rdfs:comment": "Insurance declaration for high-value shipments. Mandatory for items above IDR 5,000,000 on all major marketplaces. Affects RTO refund calculations — claim filed against insurance policy when applicable.\n"
    },
    {
      "@id": "ion:agentId",
      "@type": "rdf:Property",
      "rdfs:label": "agentId",
      "rdfs:comment": "Platform-issued agent ID that consumer can verify against BPP app or logistics app. More trustworthy than name alone — prevents impersonation scams.\n"
    },
    {
      "@id": "ion:agentVehicleType",
      "@type": "rdf:Property",
      "rdfs:label": "agentVehicleType",
      "rdfs:comment": "Agent vehicle type — affects delivery ETA and corporate policy"
    },
    {
      "@id": "ion:agentPlateNumber",
      "@type": "rdf:Property",
      "rdfs:label": "agentPlateNumber",
      "rdfs:comment": "Indonesian vehicle plate (Nomor Polisi). Required by some corporate buyers for building access."
    },
    {
      "@id": "ion:agentBadgeNumber",
      "@type": "rdf:Property",
      "rdfs:label": "agentBadgeNumber",
      "rdfs:comment": "Physical badge number the agent carries. Consumers verify at door. Distinct from agentId which is internal.\n"
    },
    {
      "@id": "ion:liveAgentLocationUrl",
      "@type": "rdf:Property",
      "rdfs:label": "liveAgentLocationUrl",
      "rdfs:comment": "URL for live agent location tracking (distinct from trackingUrl which is package-centric). Agent-centric view consumers use during OUT_FOR_DELIVERY for last-mile visibility.\n"
    },
    {
      "@id": "ion:qcResult",
      "@type": "rdf:Property",
      "rdfs:label": "qcResult",
      "rdfs:comment": "Quality inspection result when return package is received by seller. Determines refund amount — full for QC_PASSED, partial for QC_PARTIAL, zero for QC_FAILED_* variants (dispute-prone).\n"
    },
    {
      "@id": "ion:qcNotes",
      "@type": "rdf:Property",
      "rdfs:label": "qcNotes",
      "rdfs:comment": "Seller-provided explanation of QC findings"
    },
    {
      "@id": "ion:qcEvidence",
      "@type": "rdf:Property",
      "rdfs:label": "qcEvidence",
      "rdfs:comment": "Photo/video URLs from seller's QC inspection. Used in dispute resolution."
    },
    {
      "@id": "ion:marketplaceManagedLogistics",
      "@type": "rdf:Property",
      "rdfs:label": "marketplaceManagedLogistics",
      "rdfs:comment": "True when logistics is orchestrated by the BAP (marketplace) rather than the BPP (seller). Seller BPP handles ready-to-ship only; marketplace BAP triggers its own logistics contract. Used by Shopee Xpress, Tokopedia TokoCabang, Amazon MFN.\n"
    },
    {
      "@id": "ion:slaBreachCount",
      "@type": "rdf:Property",
      "rdfs:label": "slaBreachCount",
      "rdfs:comment": "Number of SLA TATs breached by BPP on this fulfilment. Incremented by BAP each time an expected on_status does not arrive within SLA. Persists across updates for reconciliation penalty calculation.\n"
    },
    {
      "@id": "ion:slaBreachDetails",
      "@type": "rdf:Property",
      "rdfs:label": "slaBreachDetails",
      "rdfs:comment": "Record of each SLA breach for audit trail."
    },
    {
      "@id": "ion:ageVerificationRequired",
      "@type": "rdf:Property",
      "rdfs:label": "ageVerificationRequired",
      "rdfs:comment": "Whether delivery agent must verify buyer age at door before handover. Derived from resource.ageRestricted; BPP copies to performance record. If true, delivery fails (state goes to DELIVERY_FAILED) if verification is not successfully completed.\n"
    },
    {
      "@id": "ion:ageVerificationMethod",
      "@type": "rdf:Property",
      "rdfs:label": "ageVerificationMethod",
      "rdfs:comment": "Method used to verify buyer age at delivery. KTP_SIGHTED: agent visually confirms KTP DOB. KTP_SCANNED: agent scans KTP via agent app; OCR reads DOB. SELFIE_COMPARISON: agent compares consumer face to buyer profile photo. BIOMETRIC_API: agent uses liveness + age estimation API.\n"
    },
    {
      "@id": "ion:ageVerifiedAt",
      "@type": "rdf:Property",
      "rdfs:label": "ageVerifiedAt",
      "rdfs:comment": "Timestamp of successful verification at door"
    },
    {
      "@id": "ion:ageVerifiedByAgentId",
      "@type": "rdf:Property",
      "rdfs:label": "ageVerifiedByAgentId",
      "rdfs:comment": "Agent ID of the person who performed verification"
    },
    {
      "@id": "ion:ageVerificationEvidence",
      "@type": "rdf:Property",
      "rdfs:label": "ageVerificationEvidence",
      "rdfs:comment": "URL to evidence of verification (photo of KTP with DOB visible, scan result). Retained per platform policy. Must be encrypted at rest and subject to data residency rules if applicable.\n"
    },
    {
      "@id": "ion:ageVerificationFailedReason",
      "@type": "rdf:Property",
      "rdfs:label": "ageVerificationFailedReason",
      "rdfs:comment": "Reason age verification failed at delivery. Performance state should transition to DELIVERY_FAILED with this reason tag, and RTO flow initiates. Buyer may be blocked from future purchases of this category (per platform policy).\n"
    }
  ]
}